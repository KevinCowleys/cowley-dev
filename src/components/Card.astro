---
interface Props {
  title?: string;
  body?: string;
  colSpan: string;
  rowSpan: string;
  flexContent?: string;
  addPadding?: boolean;
}

const { title, body, colSpan, rowSpan, flexContent, addPadding = true } = Astro.props;
---

<div class={`card overflow-hidden rounded-lg border border-zinc-900 hover:border-cyan-900 transform perspective-1200 w-full col-span-1
    ${flexContent || "flex-none"} ${ addPadding ? 'p-6' : ''} ${colSpan || "md:col-span-2"} ${rowSpan || ""}`}>
    <slot>
        {title && <h2 class="text-xl font-bold m-0 z-20">{title}</h2>}
        {body && <p class="m-0 font-light text-base">{body}</p>}
    </slot>
</div>
